# .env.example - Template for runtime environment configuration
# Copy this file to .env and populate with actual values.
# .env is excluded from version control via .gitignore — NEVER commit .env.

APP_ENV=production
APP_DEBUG=false

# Database connection (use a least-privilege application account, not root)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=medic_vault_db
DB_USER=medivault_app_user
DB_PASS=

# AES-256-GCM encryption key — must be exactly 64 hex characters (32 raw bytes).
# Generate a fresh key with: php -r "echo bin2hex(random_bytes(32));"
# Rotate this key by re-encrypting all stored records with the new key before deployment.
VAULT_ENCRYPTION_KEY=
